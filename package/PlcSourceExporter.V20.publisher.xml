<?xml version="1.0" encoding="utf-8"?>
<PackageConfiguration xmlns="http://www.siemens.com/automation/Openness/AddIn/Publisher/V20">
  <Author>Ansel</Author>
  <Description>Exports selected PLC source data to UserFiles\export with flat Blocks, DB, UDT, and Tags folders.</Description>
  <AddInVersion>1.0.0.0</AddInVersion>
  <Product>
    <Name>PlcSourceExporter</Name>
    <Id>PlcSourceExporter</Id>
    <Version>1.0.0.0</Version>
  </Product>
  <FeatureAssembly>
    <AssemblyInfo>
      <Assembly>..\src\PlcSourceExporter.AddIn\bin\Debug\net48\PlcSourceExporter.AddIn.dll</Assembly>
      <Pdb>..\src\PlcSourceExporter.AddIn\bin\Debug\net48\PlcSourceExporter.AddIn.pdb</Pdb>
    </AssemblyInfo>
  </FeatureAssembly>
  <AdditionalAssemblies>
    <AssemblyInfo>
      <Assembly>..\src\PlcSourceExporter.AddIn\bin\Debug\net48\PlcSourceExporter.Core.dll</Assembly>
      <Pdb>..\src\PlcSourceExporter.AddIn\bin\Debug\net48\PlcSourceExporter.Core.pdb</Pdb>
    </AssemblyInfo>
  </AdditionalAssemblies>
  <RequiredPermissions>
    <TIAPermissions>
      <TIA.ReadWrite>
        <Comment>Read PLC software objects and export their source files.</Comment>
      </TIA.ReadWrite>
    </TIAPermissions>
    <SecurityPermissions>
      <System.Security.Permissions.FileIOPermission>
        <Comment>Write export XML and log files under the TIA project UserFiles folder.</Comment>
      </System.Security.Permissions.FileIOPermission>
      <System.Security.Permissions.UIPermission>
        <Comment>Display the export progress window and completion status.</Comment>
      </System.Security.Permissions.UIPermission>
    </SecurityPermissions>
  </RequiredPermissions>
  <DisplayInMultiuser />
</PackageConfiguration>
